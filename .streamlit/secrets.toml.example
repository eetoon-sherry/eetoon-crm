# Copy this file to secrets.toml and fill in real values
# (secrets.toml is gitignored and must be configured in Streamlit Cloud UI)

[supabase]
url = "https://YOUR_PROJECT.supabase.co"
key = "sb_publishable_YOUR_KEY"
db_host = "db.YOUR_PROJECT.supabase.co"
db_password = "YOUR_DB_PASSWORD"

[smtp]
host = "smtp.qiye.163.com"
port = 465
user = "your@email.com"
password = "YOUR_SMTP_PASSWORD"
sender_name = "Sherry | EETOON GROUP"
bcc = "your_monitor@gmail.com"

[imap]
host = "imap.qiye.163.com"
port = 993
user = "your@email.com"
password = "YOUR_IMAP_PASSWORD"

[auth]
password = "YOUR_DASHBOARD_PASSWORD"

[anthropic]
api_key = ""
